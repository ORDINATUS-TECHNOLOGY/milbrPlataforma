@{
    ViewData["Title"] = "Layout";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MILBR.NET</title>

  @* LINKS *@
  <link rel="shortcut icon" href="img/favicon.png" type="image/x-icon">
  <link rel="stylesheet" href="css/puro/default.css">



  @* IMPORTS *@
  <!--- Open Sans import ---->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">


</head>
  <body>
    @* CABEÇALHO DA PÁGINA *@
    
    <header>
      <div id="cabecalho-milbr">
        @* CABEÇALHO DE CIMA QUE CONTÉM AS INFORMAÇÕES DE CONTATO *@
        <div class="cabecalho-informacoes-contato">
          <div><img src="img/socialmedia/atendente.png" alt="cabecalho-informacoes-contato-logo-usuario"><h3>Central do assinante</h3></div>
          <div></div>
          <div><img src="img/socialmedia/sacLogo.png" alt="cabecalho-informacoes-contato-logo-sac"><h3>sac@grupomilbr.com.br</h3></div>
          <div><img src="img/socialmedia/telefoneLogo.png" alt="cabecalho-informacoes-contato-logo-0800"><h3>0800 031 3571</h3></div>
          <div><img src="img/socialmedia/whatsLogo.png" alt="cabecalho-informacoes-contato-logo-whatsapp"><h3>35 3571-5000</h3></div>
          <div id="cabecalho-informacoes-contato-redes-sociais">
            <h3>ACESSE NOSSAS REDES SOCIAIS</h3>
            <div id="cabecalho-informacoes-contato-link-individual">
              <div id="cabecalho-informacoes-contato-facebook"><a href="https://www.facebook.com/Milbrnet/"><img src="img/socialmedia/facebook.png" alt="cabecalho-informacoes-contato-facebook-icon"></a></div>
              <div id="cabecalho-informacoes-contato-instagram"><a href="https://www.instagram.com/milbrnet/"><img src="img/socialmedia/instagram.png" alt="cabecalho-informacoes-contato-instagram-icon"></a></div>
              <div id="cabecalho-informacoes-contato-youtube"><a href="https://www.youtube.com/@@nocmilbr"><img src="img/socialmedia/youtube.png" alt="cabecalho-informacoes-contato-youtube-icon"></a></div>
            </div>
          </div>
        </div>
        
        @* CABEÇALHO DE BAIXO QUE CONTÉM AS LOGOS E LINKS DIRETOS DE ACESSO *@
        <ul id="cabecalho-ux-acesso-links-diretos-de-acesso">
          <td id="cabecalho-ux-acesso-links-diretos-de-acesso-logos"></td>
          <td id="cabecalho-ux-acesso-links-diretos-de-acesso-clicaveis"></td>
        </ul>
      </div>
    </header>

    @* ONDE CARREGA O CONTEUDO PRINCIPAL DE CADA LINK *@
    <main>
      @RenderBody()
    </main>
    
    @* PARTE FINAL DA PAGINA *@
    <footer>

    </footer>
  </body>
</html>
